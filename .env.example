# --- Database (auto: SQLite unless Supabase creds are set) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MODEL_HUNTER_DB_PATH=./data/model-hunter.sqlite

# --- Telegram (primary alert channel) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email backup (Resend free tier) ---
RESEND_API_KEY=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=alerts@modelhunter.local

# --- LLM providers (failover: Ollama local -> OpenAI -> NVIDIA -> Groq -> Gemini -> OpenRouter) ---
# Ollama local is the default ($0, no key). All others are optional fallbacks.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
OPENAI_API_KEY=
NVIDIA_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Tuning ---
RELEVANCE_THRESHOLD=65
DRY_RUN=false
HEARTBEAT_HOUR_UTC=8
LOG_LEVEL=info
